# MongoDB Atlas Connection String
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/attention_tracker?retryWrites=true&w=majority

# JWT Secret (Generate a strong random string - minimum 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secure-random-string-minimum-32-chars

# Email Configuration (Gmail with App Password)
# Step 1: Go to https://myaccount.google.com/apppasswords
# Step 2: Select "Mail" and "Windows Computer"
# Step 3: Copy the 16-character app password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Server Configuration
NODE_ENV=production

# CORS Origins (for production, use your Vercel domain)
CORS_ORIGIN=https://your-app-name.vercel.app

# Server Port (optional, defaults to 3000)
PORT=3000